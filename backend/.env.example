PORT=5000
NODE_ENV=development

# Database (Turso)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT
JWT_SECRET=your-jwt-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# Google Drive (for notes sync)
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# Discord (for report notifications)
DISCORD_REPORT_WEBHOOK_URL=your-discord-webhook-url

# PostHog (product analytics — get free key at https://posthog.com/signup)
POSTHOG_KEY=phc_your-project-api-key
POSTHOG_HOST=https://us.i.posthog.com

# CORS
FRONTEND_URL=http://localhost:5173
